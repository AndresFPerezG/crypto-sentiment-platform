# ==========================================================================
# Crypto Sentiment Platform — Environment Variables Template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ==========================================================================

# --- Application ---
APP_ENV=development        # development | staging | production
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json            # json | console

# --- Binance WebSocket (no auth required for public streams) ---
BINANCE_WS_URL=wss://stream.binance.com:9443
BINANCE_SYMBOLS=btcusdt,ethusdt,solusdt

# --- Postgres (local dev) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crypto_platform
POSTGRES_USER=crypto_user
POSTGRES_PASSWORD=changeme_in_real_env

# --- MinIO (S3-compatible local storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# --- Redpanda (Kafka-compatible) ---
REDPANDA_BROKERS=localhost:19092
REDPANDA_SCHEMA_REGISTRY=http://localhost:18081

# --- External APIs (later weeks) ---
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# GDELT_API_BASE=https://api.gdeltproject.org/api/v2

# --- Slack alerts (later weeks) ---
# SLACK_WEBHOOK_URL=
